{
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://acctos-aiapi-production.up.railway.app/api/:path*" },
    { "source": "/v1/:path*",  "destination": "https://acctos-aiapi-production.up.railway.app/v1/:path*" },
    { "source": "/(.*)",       "destination": "/index.html" }
  ]
}
